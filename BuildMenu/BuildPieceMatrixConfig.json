  "overrides": {
    "placement_rules": {
      "_comment": "Unified top/full placement overrides. Ordered first-match wins. property: prefab|name|combined(prefab+name)|category|crafting_station|interaction_hooks|system_effects, match_type: exact|regex (this will be case-insenstive), patterns: string[], top required, subcategory optional. This is the first precedence.",
      "rules": [
        {
          "property": "name",
          "match_type": "regex",
          "patterns": [
            "\\[tag_",
            "\\[piece_"
          ],
          "top": "Unknown",
          "subcategory": "UnLocalized"
        },
        { 
          "property": "name",
          "match_type": "exact",
          "patterns": [
            "Finewood Wall Roof 64°"
          ],
          "subcategory": "No Cost",
          "top": "Unknown"
        },
        { 
          "property": "prefab",
          "match_type": "exact",
          "patterns": [
            "piece_repair"
          ],
          "subcategory": "Repair",
          "top": "Repair"
        },
        {
          "property": "combined",
          "match_type": "regex",
          "patterns": [
            "tree"
          ],
          "top": "Building",
          "subcategory": "Trees"
        },
        { 
          "property": "interaction_hooks",
          "match_type": "exact",
          "patterns": [
            "ship"
          ],
          "top": "Crafting",
          "subcategory": "Ships"
